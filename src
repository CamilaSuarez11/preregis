import pytest

from screenpy import Actor

from credit_card.tasks.get_card_status import GetCardStatus
from credit_card.questions.card_status_body import CardStatusBody
from credit_card.data.card_data import (
    VALID_CARD_ID,
    INVALID_CARD_ID,
    OTHER_USER_CARD_ID
)


def test_card_status_success(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatus(VALID_CARD_ID)
    )

    response = CardStatusBody().answered_by(the_actor)

    assert response.payload is not None
    assert response.errors is None


def test_card_not_found(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatus(INVALID_CARD_ID)
    )

    response = CardStatusBody().answered_by(the_actor)

    assert response.payload == {}
    assert response.errors is not None


def test_card_other_user(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatus(OTHER_USER_CARD_ID)
    )

    response = CardStatusBody().answered_by(the_actor)

    assert response.errors is not None


def test_card_without_token(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatus(VALID_CARD_ID, with_token=False)
    )

    response = CardStatusBody().answered_by(the_actor)

    assert response is not None

