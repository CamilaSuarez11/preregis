import screenpy
from screenpy import Actor
from screenpy.pacing import beat

from bold_platform_regression.backend.banking.commons import call_api
from credit_card.repository.credit_card_repository import CreditCardEndpoints
from bold_platform_regression.backend.banking.commons.questions import what_is_my
from bold_platform_regression.backend.banking.commons.utils import http_constants
from bold_platform_regression.backend.banking.commons import base


class GetCardStatus:

    def __init__(self, card_id: int, with_token: bool = True):
        self.card_id = card_id
        self.with_token = with_token

    @beat("{0} gets card status")
    def perform_as(self, the_actor: Actor) -> None:

        url = base.Url.BaseUrl.backend_mobile() + \
              CreditCardEndpoints.GET_CARD_STATUS.format(card_id=self.card_id)

        if self.with_token:
            the_actor.attempts_to(
                call_api.SetHeaders(
                    http_constants.HEADER_NAME_AUTH,
                    http_constants.HEADER_VALUE_OAUTH2 %
                    what_is_my.api_token().answered_by(the_actor)
                )
            )

        the_actor.attempts_to(
            call_api.SendGETRequest.to(url)
        )

