import pytest_bdd
from screenpy import Actor

from bold_platform_regression.backend.banking.credit_card.tasks.get_card_status_task import GetCardStatusTask
from bold_platform_regression.backend.banking.credit_card.data.factory.card_factory import CardFactory
from bold_platform_regression.backend.banking.credit_card.questions.get_card_status import GetCardStatusQuestion

pytest_bdd.scenarios("../features/get_card_status.feature")


# ======================
# GIVEN
# ======================
@pytest_bdd.given("user has a valid token")
def user_has_token():
    pass


# ======================
# WHEN
# ======================
@pytest_bdd.when("user gets card status with valid card")
def valid_card(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatusTask(CardFactory.VALID_CARD_ID)
    )


@pytest_bdd.when("user gets card status with invalid card")
def invalid_card(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatusTask(CardFactory.INVALID_CARD_ID)
    )


@pytest_bdd.when("user gets card status without token")
def no_token(the_actor: Actor):
    the_actor.attempts_to(
        GetCardStatusTask(CardFactory.VALID_CARD_ID, with_token=False)
    )


# ======================
# THEN
# ======================
@pytest_bdd.then("response status should be 200")
def validate_200(the_actor: Actor):
    assert the_actor.recall("last_response").status_code == 200


@pytest_bdd.then("response status should be 404")
def validate_404(the_actor: Actor):
    assert the_actor.recall("last_response").status_code == 404


@pytest_bdd.then("response status should be 401")
def validate_401(the_actor: Actor):
    assert the_actor.recall("last_response").status_code == 401


@pytest_bdd.then("card status should be active")
def validate_status(the_actor: Actor):
    response = GetCardStatusQuestion().answered_by(the_actor)
    assert response.payload.status == "active"

