from commons.screenplay.questions import question


class TheCardResponse:

    def answered_by(self, the_actor):
        return the_actor.asks_for(
            question.TheLastBodyResponse()
        )


class TheCardStatus:

    def answered_by(self, the_actor):
        body = the_actor.asks_for(
            question.TheLastBodyResponse()
        )
        return body.get("status")

