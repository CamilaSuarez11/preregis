from commons.screenplay.questions import what_is
from backend.banking.credit_card.model.response.card_response import CardResponse


class Card:

    def answered_by(self, the_actor):
        response = what_is.TheLastResponse.body().answered_by(the_actor)
        return CardResponse(**response)


class CardStatus:

    def answered_by(self, the_actor):
        return Card().answered_by(the_actor).status


class CardId:

    def answered_by(self, the_actor):
        return Card().answered_by(the_actor).id


class ErrorMessage:

    def answered_by(self, the_actor):
        response = what_is.TheLastResponse.body().answered_by(the_actor)
        return response.get("message")

