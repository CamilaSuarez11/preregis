
function fn() {

  var config = {};

  var env = karate.env;
  if (!env) env = 'lab';

  // Hosts
  config.awsHost = 'https://privateapilab.davivienda.loc';

  // 🔥 CARGAR JSON UNA SOLA VEZ
  config.canales = karate.read('classpath:canales.json');
  config.dominios = karate.read('classpath:dominios.json');

  // 🔥 OBTENER CANAL ID
  config.getCanalId = function(xname){
    var canal = config.canales[xname];

    if (!canal) {
      throw 'No existe configuración para xname: ' + xname;
    }

    return canal.id;
  };

  // 🔥 HEADERS DINÁMICOS
  config.buildHeaders = function(xname, dominio){

    var uuid = java.util.UUID.randomUUID() + '';

    var canal = config.canales[xname];
    var dominioConf = config.dominios[dominio];

    if (!canal) {
      throw 'No existe configuración para xname: ' + xname;
    }

    return {
      'Content-Type': 'text/xml; charset=UTF-8',
      'x-api-key': canal.key,
      'x-apigw-api-id': dominioConf.apiId,
      'X-Name': xname,
      'X-RqUID': uuid,
      'SOAPAction': ''
    };
  };

  karate.configure('connectTimeout', 5000);
  karate.configure('readTimeout', 5000);

  return config;
}
