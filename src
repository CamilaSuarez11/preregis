function fn() {

  var env = karate.env;
  if (!env) {
    env = 'lab';
  }

  var config = {};

  // 👇 ESTA ES LA LÍNEA QUE FALTABA
  var properties = read('classpath:' + env + '.properties');

  // Hosts
  config.awsHost = properties['aws.host'];
  config.busHost = properties['bus.host'];

  // Headers
  config.awsHeaders = {
    'Content-Type': 'text/xml; charset=UTF-8',
    'x-api-key': properties['aws.api.key'],
    'x-apigw-api-id': properties['aws.api.id'],
    'SOAPAction': ''
  };

  // SSL
  karate.configure('ssl', {
    keyStore: 'classpath:tester.jks',
    keyStorePassword: properties['keystore.password']
  });

  karate.configure('connectTimeout', 5000);
  karate.configure('readTimeout', 5000);

  return config;
}
