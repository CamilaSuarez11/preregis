import pytest_bdd

from backend.banking.credit_card.actions.get_card_status import GetCardStatus
from backend.banking.credit_card.questions.get_card_status import (
    CardPayload,
    CardErrors,
    CardStatus,
    ErrorMessage
)
from backend.banking.credit_card.data.card_data import CardData
from backend.banking.credit_card.utils.constants import cards_constants


pytest_bdd.scenarios("../features/get_card_status.feature")


@pytest_bdd.given("Alejandra is authenticated")
def alejandra_authenticated(the_actor):
    pass


@pytest_bdd.given("Alejandra without token")
def alejandra_without_token(the_actor):
    the_actor.remember("api_token", "")


@pytest_bdd.when("Alejandra gets card status with valid card id")
def get_valid_card(the_actor):
    the_actor.attempts_to(
        GetCardStatus(CardData.valid_card())
    )


@pytest_bdd.when("Alejandra gets card status with invalid card id")
def get_invalid_card(the_actor):
    the_actor.attempts_to(
        GetCardStatus(CardData.invalid_card())
    )


@pytest_bdd.then("Alejandra should see correct card information")
def validate_success(the_actor):
    payload = CardPayload().answered_by(the_actor)

    assert payload is not None

    assert isinstance(payload.id, int)
    assert isinstance(payload.name, str)
    assert isinstance(payload.card_type, str)
    assert isinstance(payload.status, str)
    assert isinstance(payload.has_pin, bool)

    assert payload.id == CardData.valid_card()
    assert payload.status == cards_constants.STATUS_ACTIVE
    assert payload.card_type == cards_constants.CARD_TYPE_PHYSICAL

    assert payload.user.id > 0
    assert "@" in payload.user.email
    assert payload.user.first_name != ""
    assert payload.user.last_name != ""
    assert isinstance(payload.user.suspended, bool)
    assert payload.user.cellphone.isdigit()

    assert payload.issuer.id > 0
    assert "@" in payload.issuer.email
    assert payload.issuer.first_name != ""
    assert payload.issuer.last_name != ""
    assert isinstance(payload.issuer.suspended, bool)
    assert payload.issuer.cellphone.isdigit()

    errors = CardErrors().answered_by(the_actor)
    assert errors is None


@pytest_bdd.then("Alejandra should see not found error")
def validate_not_found(the_actor):
    error = ErrorMessage().answered_by(the_actor)

    assert error == cards_constants.ERROR_NOT_FOUND


@pytest_bdd.then("Alejandra should see unauthorized error")
def validate_unauthorized(the_actor):
    error = ErrorMessage().answered_by(the_actor)

    assert error == cards_constants.ERROR_UNAUTHORIZED

