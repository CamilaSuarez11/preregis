import screenpy
from screenpy import pacing

from commons.screenplay.actions import call_api
from commons.screenplay.questions import what_is

from backend.commons.utils.uri import base_url
from backend.banking.credit_card.utils import credit_card as credit_card_paths


class GetCardStatus:

    def __init__(self, card_id: int):
        self.card_id = card_id

    @classmethod
    def with_id(cls, card_id: int):
        return cls(card_id)

    @pacing.beat("{} gets credit card status")
    def perform_as(self, the_actor: screenpy.AnActor) -> None:
        endpoint = (
            base_url.BaseUrl.credit_card()
            + credit_card_paths.CARD_ID.format(card_id=self.card_id)
        )

        token: str = what_is.My.api_token().answered_by(the_actor)

        the_actor.attempts_to(
            call_api.SetHeaders(
                "authorization",
                f"Bearer {token}",
                "accept",
                "application/json",
            ),
            call_api.SendGETRequest.to(endpoint),
        )
