from commons.screenplay.actions import call_api
from commons.screenplay.utils import http_constants
from commons.utils.uri import base_url
from commons.utils.uri import credit_card as credit_card_paths


class GetCardStatus:

    def __init__(self, card_id: int):
        self.card_id = card_id

    @staticmethod
    def with_id(card_id: int):
        return GetCardStatus(card_id)

    def perform_as(self, the_actor):

        url = (
            base_url.BaseUrl.credit_card()
            + credit_card_paths.CARD_ID.format(card_id=self.card_id)
        )

        the_actor.attempts_to(
            call_api.CallApi(
                method=http_constants.GET,
                url=url
            )
        )
