aws.api.key=XXXXXXX
aws.api.id=YYYYYYY

# SSL
keystore.password=davitech

# HOSTS
bus.host=http://wmblab.davivienda.loc:9212
aws.host=https://privateapilab.davivienda.loc



function fn() {

  var env = karate.env;
  if (!env) {
    env = 'lab';
  }

  karate.log('Ambiente:', env);

  // Carga automática del properties según el ambiente
  var properties = read('classpath:' + env + '.properties');

  var config = {};

  config.busHost = properties['bus.host'];
  config.awsHost = properties['aws.host'];

  config.busPath = '/ESBService/TechnologyAdapter';
  config.awsPath = '/stage/ESBService/ConsultarCuentaClienteP2M';

  config.busHeaders = {
    'Content-Type': 'text/xml; charset=UTF-8',
    'SOAPAction': ''
  };

  config.awsHeaders = {
    'Content-Type': 'text/xml; charset=UTF-8',
    'x-api-key': properties['aws.api.key'],
    'x-apigw-api-id': properties['aws.api.id'],
    'X-Name': 'PN-SUPERAPP',
    'X-Rquid': java.util.UUID.randomUUID() + '',
    'SOAPAction': ''
  };

  karate.configure('ssl', {
    keyStore: 'classpath:tester.jks',
    keyStorePassword: properties['keystore.password']
  });

  karate.configure('connectTimeout', 5000);
  karate.configure('readTimeout', 5000);
  karate.configure('logPrettyRequest', true);
  karate.configure('logPrettyResponse', true);

  return config;
}
