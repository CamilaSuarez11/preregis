ACTION 

import screenplay
from screenplay import actions, pacing

from backend.commons.utils.uri import base_url
from commons.screenplay.actions import call_api
from commons.screenplay.questions import what_is


class GetCardStatus:

    def __init__(self, card_id: int):
        self.card_id = card_id

    @pacing.beat("{} gets card status")
    def perform_as(self, the_actor: screenplay.AnActor) -> None:

        url = base_url.BaseUrl.credit_card() + f"/cards/{self.card_id}"

        token = what_is.My.api_token().answered_by(the_actor)

        the_actor.attempts_to(
            actions.call_api.SetHeaders(
                "Authorization",
                f"Bearer {token}",
                "accept",
                "application/json",
            ),
            call_api.SendGETRequest.to(url),
        )
