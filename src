
import screenplay
from screenplay import pacing

from backend.banking.credit_card.actions.get_card_status import GetCardStatus


class GetCardStatusTask:

    def __init__(self, card_id: int):
        self.card_id = card_id

    @classmethod
    def with_id(cls, card_id: int):
        return cls(card_id)

    @pacing.beat("{} gets card status")
    def perform_as(self, the_actor: screenplay.AnActor) -> None:
        the_actor.attempts_to(
            GetCardStatus(self.card_id)
        )
