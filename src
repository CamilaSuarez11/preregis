import pytest
import pytest_bdd

from commons.screenplay.actors import the_actor_character
from commons.screenplay.actors import bold_actors

from backend.banking.credit_card.tasks.get_card_status import GetCardStatusTask
from backend.banking.credit_card.questions.card_status_questions import TheCardStatus
from backend.banking.credit_card.utils.constants import cards_constants


pytest_bdd.scenarios("../features/get_card_status.feature")


@pytest.fixture
def the_actor():
    return bold_actors.TheActor()


# =========================
# GIVEN
# =========================
@pytest_bdd.given("Alejandra is authenticated")
def aleja_authenticated(the_actor):
    the_actor.for_api_called(
        the_actor_character.Character.ALEJANDRA
    )


# =========================
# WHEN
# =========================
@pytest_bdd.when("Alejandra gets card status with valid card")
def get_valid_card(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.VALID_CARD_ID)
    )


@pytest_bdd.when("Alejandra gets card status with invalid card")
def get_invalid_card(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.INVALID_CARD_ID)
    )


@pytest_bdd.when("Alejandra gets card status with other user card")
def get_other_user_card(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.OTHER_USER_CARD_ID)
    )


# =========================
# THEN - STATUS CODE
# =========================
@pytest_bdd.then("response status should be 200")
def status_200(the_actor):
    the_actor.should(
        bold_actors.See.the_response_status_code().is_equal_to(200)
    )


@pytest_bdd.then("response status should be 404")
def status_404(the_actor):
    the_actor.should(
        bold_actors.See.the_response_status_code().is_equal_to(404)
    )


@pytest_bdd.then("response status should be 403")
def status_403(the_actor):
    the_actor.should(
        bold_actors.See.the_response_status_code().is_equal_to(403)
    )


# =========================
# THEN - BUSINESS VALIDATION
# =========================
@pytest_bdd.then("card status should be active")
def validate_card_status(the_actor):
    status = TheCardStatus().answered_by(the_actor)
    assert status.lower() == "active"
