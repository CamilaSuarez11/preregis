function fn() {
  var env = karate.env;
  if (!env) env = 'lab';

  var config = {};

  // Hosts
  config.awsHost = 'https://privateapilab.davivienda.loc';
  config.busHost = 'http://wmblab.davivienda.loc';

  // Paths
  config.awsPath = '/stage/ESBService/ConsultarCuentasInscritas';
  config.busPath = '/ESBService/TechnologyAdapter';

  // Cargar catálogos
  var canales = karate.read('classpath:canales.json');
  var dominios = karate.read('classpath:dominios.json');

  config.getCanalInfo = function(xname) {
    var canalInfo = canales[xname];
    if (!canalInfo) {
      throw new Error('No existe xname en canales.json: ' + xname);
    }
    return canalInfo;
  };

  config.getCanalId = function(xname) {
    return config.getCanalInfo(xname).id;
  };

  config.buildHeaders = function(xname, dominio) {
    var canalInfo = config.getCanalInfo(xname);
    var dominioInfo = dominios[dominio];

    if (!dominioInfo) {
      throw new Error('No existe dominio en dominios.json: ' + dominio);
    }

    return {
      'Content-Type': 'text/xml; charset=UTF-8',
      'x-api-key': canalInfo.key,
      'x-apigw-api-id': dominioInfo.apiId,
      'X-Name': canalInfo.name,
      'X-RqUid': java.util.UUID.randomUUID() + '',
      'SOAPAction': ''
    };
  };

  karate.configure('ssl', {
    keyStore: 'classpath:tester.jks',
    keyStorePassword: 'davitech'
  });

  karate.configure('connectTimeout', 5000);
  karate.configure('readTimeout', 5000);

  return config;
}
