import pytest
import pytest_bdd

from commons.screenplay.actors import bold_actors, the_actor_character
from commons.screenplay.questions import what_is

from backend.banking.credit_card.tasks.get_card_status import GetCardStatusTask
from backend.banking.credit_card.questions.get_card_status import (
    CardStatus,
    CardId,
    ErrorMessage,
)
from backend.banking.credit_card.utils.constants import cards_constants


pytest_bdd.scenarios("../features/get_card_status.feature")


@pytest.fixture
def the_actor():
    return bold_actors.TheActor()


@pytest_bdd.given("Alejandra is authenticated")
def alejandra_is_authenticated(the_actor):
    the_actor.for_api_called(
        the_actor_character.Character.ALEJANDRA
    )


@pytest_bdd.when("Alejandra gets valid card status")
def alejandra_gets_valid_card_status(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.VALID_CARD_ID)
    )


@pytest_bdd.when("Alejandra gets invalid card status")
def alejandra_gets_invalid_card_status(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.INVALID_CARD_ID)
    )


@pytest_bdd.when("Alejandra gets other user card status")
def alejandra_gets_other_user_card_status(the_actor):
    the_actor.attempts_to(
        GetCardStatusTask.with_id(cards_constants.OTHER_USER_CARD_ID)
    )


@pytest_bdd.then("Alejandra should see status code 200")
def alejandra_should_see_status_code_200(the_actor):
    status_code = what_is.TheLastResponse.status_code().answered_by(the_actor)
    assert status_code == 200


@pytest_bdd.then("Alejandra should see status code 404")
def alejandra_should_see_status_code_404(the_actor):
    status_code = what_is.TheLastResponse.status_code().answered_by(the_actor)
    assert status_code == 404


@pytest_bdd.then("Alejandra should see status code 403")
def alejandra_should_see_status_code_403(the_actor):
    status_code = what_is.TheLastResponse.status_code().answered_by(the_actor)
    assert status_code == 403


@pytest_bdd.then("Alejandra should see correct card information")
def alejandra_should_see_correct_card_information(the_actor):
    assert CardId().answered_by(the_actor) == cards_constants.VALID_CARD_ID
    assert CardStatus().answered_by(the_actor) == "ACTIVE"


@pytest_bdd.then("Alejandra should see error message")
def alejandra_should_see_error_message(the_actor):
    message = ErrorMessage().answered_by(the_actor)
    assert message is not None

