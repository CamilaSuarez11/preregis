from commons.screenplay.questions import what_is
from backend.banking.credit_card.model.response.get_card_status_response import (
    GetCardStatusResponse,
    UnauthorizedResponse
)


class RawResponse:

    def answered_by(self, the_actor):
        return what_is.TheLastResponse.body().answered_by(the_actor)


class CardResponse:

    def answered_by(self, the_actor):
        body = RawResponse().answered_by(the_actor)

        if "message" in body and "payload" not in body:
            return UnauthorizedResponse(**body)

        return GetCardStatusResponse(**body)


class CardPayload:

    def answered_by(self, the_actor):
        return CardResponse().answered_by(the_actor).payload


class CardErrors:

    def answered_by(self, the_actor):
        return CardResponse().answered_by(the_actor).errors


class CardStatus:

    def answered_by(self, the_actor):
        return CardPayload().answered_by(the_actor).status


class ErrorMessage:

    def answered_by(self, the_actor):
        response = CardResponse().answered_by(the_actor)

        if hasattr(response, "errors") and response.errors:
            return response.errors[0].message

        if hasattr(response, "message"):
            return response.message

        return None

