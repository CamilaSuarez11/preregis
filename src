import screenpy
from screenpy.pacing import beat

from bold_platform_regression.backend.commons import call_api, base
from bold_platform_regression.backend.commons.questions import what_is_my
from bold_platform_regression.backend.commons.utils import http_constants

from bold_platform_regression.backend.banking.credit_card.repository.credit_card_repository import CreditCardRepository


class GetCardStatus:

    def __init__(self, card_id: int, with_token: bool = True):
        self.card_id = card_id
        self.with_token = with_token

    @beat("{0} gets credit card status")
    def perform_as(self, the_actor: screenpy.Actor) -> None:

        endpoint = CreditCardRepository.GET_CARD_STATUS.format(card_id=self.card_id)
        url = base.Url.BaseUrl.backend_mobile() + endpoint

        if self.with_token:
            the_actor.attempts_to(
                call_api.SetHeaders(
                    http_constants.HEADER_NAME_AUTH,
                    http_constants.HEADER_VALUE_OAUTH2 %
                    what_is_my.api_token().answered_by(the_actor)
                )
            )

        the_actor.attempts_to(
            call_api.SendGETRequest.to(url)
        )
