import pydantic
from typing import Optional, List


class User(pydantic.BaseModel):
    id: int
    email: str
    first_name: str
    last_name: str
    suspended: bool
    cellphone: str


class Issuer(User):
    pass


class Payload(pydantic.BaseModel):
    id: int
    name: str
    card_type: str
    status: str
    has_pin: bool
    issuer: Issuer
    user: User


class Error(pydantic.BaseModel):
    message: str
    type: str


class GetCardStatusResponse(pydantic.BaseModel):
    payload: Optional[Payload] = None
    errors: Optional[List[Error]] = None


class UnauthorizedResponse(pydantic.BaseModel):
    message: str


